# Local bind port. The server listens on 127.0.0.1 only.
PORT=5173

# Upstream API endpoint. Use your own provider URL.
UPSTREAM_BASE_URL=https://api.example.com

# Real upstream API key. Never commit your real key.
UPSTREAM_API_KEY=replace-with-real-upstream-key

# Upstream protocol: "openai" or "gemini".
# Gemini models always use gemini protocol regardless of this setting;
# this only controls the fallback for non-Gemini models.
UPSTREAM_PROTOCOL=openai

# Runtime website-key database. Copy keys.example.json to this path first.
SITE_KEYS_FILE=keys.json

# Runtime model/provider routing database. Copy model-routes.example.json to this path first.
MODEL_ROUTES_FILE=model-routes.json

# Admin API token for /admin.html and /api/admin/*.
ADMIN_TOKEN=replace-with-admin-token

# Upstream request timeout in seconds. 4K/multi-image requests can be slow.
UPSTREAM_TIMEOUT=600

# Comma-separated Host headers the server will accept.
# 127.0.0.1:PORT, localhost:PORT and [::1]:PORT are always allowed.
# Add your reverse-proxy hostname here when deploying behind Caddy/Nginx,
# e.g. ALLOWED_HOSTS=img-gener.example.com
ALLOWED_HOSTS=

# Comma-separated Origin values allowed to make cross-origin requests (CORS).
# Empty by default — same-origin requests work without configuration.
# Set this only if you embed the UI on another origin.
ALLOWED_ORIGINS=

# Prompt gallery sync options. Used by scripts/sync_prompt_assets.py.
IMG_GENER_ROOT=/opt/img-gener
AWESOME_PROMPT_REPO_URL=https://github.com/freestylefly/awesome-gpt-image-2.git
BANANA_PROMPT_REPO_URL=https://github.com/glidea/banana-prompt-quicker.git
SKIP_BANANA_NSFW=1
