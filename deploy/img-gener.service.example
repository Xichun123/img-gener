[Unit]
Description=Img Gener image generation console
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/img-gener
EnvironmentFile=/opt/img-gener/.env
ExecStart=/usr/bin/python3 /opt/img-gener/server.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
